<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_round_bg"
    android:orientation="vertical"
    android:clipToOutline="true">

    <!-- Верхняя полоса (Header) -->
    <RelativeLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF9AA3B2"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <ImageView
            android:id="@+id/btn_edit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:contentDescription=""
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_edit_24" />

        <TextView
            android:id="@+id/header_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_toStartOf="@id/btn_edit"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="#FF1C1C1E"
            android:textSize="16sp" />
    </RelativeLayout>

    <!-- Разделитель -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:background="#FF6B7280"
        android:contentDescription="@null" />

    <!-- Список -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFEDEFF3">

        <ListView
            android:id="@+id/widget_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFEDEFF3"
            android:divider="@null" />

        <TextView
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/widget_warning_empty_data"
            android:textColor="#FF6B7280"
            android:textSize="18sp"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
