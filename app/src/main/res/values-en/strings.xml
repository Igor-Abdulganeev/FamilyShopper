    <string name="app_name">Family Shopping</string>

    <string name="help_client_key_property">Your user key lets you use private lists and control access to lists you create:\n * No restrictions — anyone can edit the list\n * Limited editing — others can only check off items\n * Read-only — others can only view the list\n * Private — only you can see the list\n\nImportant: Changing this key will revoke access to your private lists and prevent you from updating permissions on previously created restricted lists.</string>

    <string name="help_group_key_property">"This key is used to access your list storage:\n * Create a new key — start a new storage\n * Enter an existing key — restore your previous data\n * Enter someone else's key — access shared lists\n\nWithout a key, lists are stored on this device only."</string>

    <string name="help_keys_property">We recommend saving these keys so you can restore your lists after reinstalling the app.</string>

